{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["tsconfig.base.json", ".npmrc", "pnpm-workspace.yaml"],
  "tasks": {
    "//#lint": {
      "inputs": [
        "eslint.config.mjs",
        "*.{ts,tsx,js,mjs,cjs}",
        ".github/**/*.{ts,js,mjs,cjs}",
        "packages/**/*.{ts,tsx,js,mjs,cjs}",
        "workers/**/*.{ts,tsx,js,mjs,cjs}",
        "variants/**/*.{ts,tsx,js,mjs,cjs}",
        "tools/**/*.{ts,tsx,js,mjs,cjs}"
      ]
    },
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["topo", "^build"],
      "outputs": ["dist/**"]
    },
    "@pm/front#build": {
      "dependsOn": ["topo", "^build"],
      // The home surface's receipts are substituted from the crate manifest
      // (ADR-0007) — without this input, a crate re-freeze that touches
      // nothing under workers/front would replay a cached dist carrying the
      // OLD receipts, and the deploy leg would ship it before the post-deploy
      // smoke caught the drift.
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tools/snapshot-capture/crate/manifest.json"],
      "outputs": ["dist/**"]
    },
    "@pm/vanilla#build": {
      "dependsOn": ["topo", "^build"],
      // PM_SNAPSHOT is THE snapshot selector for snapshot-parameterized
      // variant builds (minted by the editorial build's slice A; every later
      // build-time variant declares it the same way): fixture default, crate
      // on the deploy job. The origin job and the deploy job share the
      // turbo-origin-* cache family — without this env declaration (and the
      // tray inputs below) the deploy job would replay the origin job's
      // fixture-flavored dist straight onto the crate-serving plane.
      "env": ["PM_SNAPSHOT"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tools/snapshot-fixture/snapshot/*.json",
        "$TURBO_ROOT$/tools/snapshot-capture/crate/*.json"
      ],
      "outputs": ["dist/**"]
    },
    "@pm/react-next#build": {
      "dependsOn": ["topo", "^build"],
      // Not snapshot-parameterized for the TRAYS (request-time variant,
      // editorial-build slice B — fetched through the edge Worker per
      // request, no PM_SNAPSHOT env declaration needed here) — but
      // src/lib/snapshot.ts statically imports the fixture's committed
      // manifest.json/curation.json at build time (to resolve the
      // featured-id policy without a hardcoded crate-name string); without
      // these as declared inputs, regenerating the fixture would replay a
      // stale cached bundle (verify-slice finding — the
      // @pm/vanilla#build precedent above, same hazard, narrower cause).
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tools/snapshot-fixture/snapshot/manifest.json",
        "$TURBO_ROOT$/tools/snapshot-fixture/snapshot/curation.json"
      ],
      // Output is the OpenNext bundle, not the generic "dist/**" every
      // other variant uses.
      "outputs": [".open-next/**"]
    },
    "dev": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["topo"]
    },
    "test": {
      "dependsOn": ["topo"]
    },
    "@pm/reference#test": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tools/snapshot-fixture/snapshot/**",
        "$TURBO_ROOT$/docs/adr/*.md",
        "$TURBO_ROOT$/docs/build-log.md"
      ]
    },
    "@pm/repo-checks#test": {
      "cache": false
    }
  }
}
