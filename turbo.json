{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["tsconfig.base.json", ".npmrc", "pnpm-workspace.yaml"],
  "tasks": {
    "//#lint": {
      "inputs": [
        "eslint.config.mjs",
        "*.{ts,tsx,js,mjs,cjs}",
        ".github/**/*.{ts,js,mjs,cjs}",
        "packages/**/*.{ts,tsx,js,mjs,cjs}",
        "workers/**/*.{ts,tsx,js,mjs,cjs}",
        "variants/**/*.{ts,tsx,js,mjs,cjs}",
        "tools/**/*.{ts,tsx,js,mjs,cjs}"
      ]
    },
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["topo", "^build"],
      "outputs": ["dist/**"]
    },
    "@pm/front#build": {
      "dependsOn": ["topo", "^build"],
      // The home surface's receipts are substituted from the crate manifest
      // (ADR-0007) — without this input, a crate re-freeze that touches
      // nothing under workers/front would replay a cached dist carrying the
      // OLD receipts, and the deploy leg would ship it before the post-deploy
      // smoke caught the drift.
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/tools/snapshot-capture/crate/manifest.json"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["topo"]
    },
    "test": {
      "dependsOn": ["topo"]
    },
    "@pm/reference#test": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tools/snapshot-fixture/snapshot/**",
        "$TURBO_ROOT$/docs/adr/*.md",
        "$TURBO_ROOT$/docs/build-log.md"
      ]
    },
    "@pm/repo-checks#test": {
      "cache": false
    }
  }
}
