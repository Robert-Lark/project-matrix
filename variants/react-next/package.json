{
  "name": "@pm/react-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/copy-tokens.mjs && opennextjs-cloudflare build",
    "dev": "wrangler dev --port 8793 --inspector-port 9236",
    "deploy": "node scripts/copy-tokens.mjs && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "@pm/data-contract": "workspace:*",
    "@pm/tokens": "workspace:*",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@opennextjs/cloudflare": "1.20.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5",
    "wrangler": "^4.110.0"
  }
}
